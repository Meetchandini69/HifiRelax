# ============================================================
# EliteEscorts Frontend — Local Development
# Copy this file to .env.local
# ============================================================

# For local development — Vite dev server port
PORT=3000

# Base path for the app. Use "/" for local dev, or "/classifieds/" for Replit
BASE_PATH=/

# (Optional) Override the API URL for Cloudflare Pages or external deployment
# Leave empty for local development (uses Vite proxy to localhost:8080)
# VITE_API_URL=https://api.yourdomain.com
